# Copy to .env.production on the deployment host. Never commit real values.

DJANGO_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=sentinell.example.com
CSRF_TRUSTED_ORIGINS=https://sentinell.example.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://sentinell.example.com

DB_NAME=sentinell_ai_db
DB_USER=sentinell_user
DB_PASSWORD=replace-with-a-strong-database-password

FERNET_KEY=replace-with-a-32-byte-url-safe-base64-key
TOKEN_VAULT_PROVIDER=ml-kem-1024-aesgcm-v1
TOKEN_VAULT_KEY_ID=mlkem1024-production-v1
MLKEM1024_PUBLIC_KEY=replace-with-base64-mlkem1024-public-key
MLKEM1024_PRIVATE_KEY=replace-with-base64-mlkem1024-private-seed

SEMANTIC_AGENT_ENABLED=True
SEMANTIC_LOCAL_EMBEDDINGS_ENABLED=True
SEMANTIC_EMBEDDING_DIMENSIONS=4096
SEMANTIC_EMBEDDING_BLOCK_THRESHOLD=0.22
SEMANTIC_EMBEDDING_ESCALATION_THRESHOLD=0.14
SEMANTIC_EMBEDDING_MIN_MARGIN=0.06
SEMANTIC_AGENT_PROVIDER=groq
GROQ_API_KEY=replace-with-groq-api-key
GROQ_SEMANTIC_MODEL=llama-3.3-70b-versatile

LLM_PROVIDER=groq
LLM_ALLOWED_PROVIDERS=mock,groq,openai,xai,openai_compatible
GROQ_RESPONSE_MODEL=llama-3.3-70b-versatile
OPENAI_RESPONSE_MODEL=gpt-4o-mini
XAI_RESPONSE_MODEL=grok-4.20-reasoning
LLM_OPENAI_COMPATIBLE_URL=
LLM_OPENAI_COMPATIBLE_API_KEY=
LLM_OPENAI_COMPATIBLE_MODEL=
LLM_TIMEOUT=20

FILE_SCAN_MAX_BYTES=5242880
FILE_SCAN_MAX_TEXT_CHARS=100000

ENTERPRISE_SSO_ENABLED=False
OIDC_PROVIDER_NAME=enterprise-oidc
OIDC_ISSUER=https://identity.example.com/oauth2/default
OIDC_AUTHORIZE_URL=https://identity.example.com/oauth2/default/v1/authorize
OIDC_TOKEN_URL=https://identity.example.com/oauth2/default/v1/token
OIDC_JWKS_URL=https://identity.example.com/oauth2/default/v1/keys
OIDC_CLIENT_ID=replace-with-oidc-client-id
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
OIDC_REDIRECT_URI=https://sentinell.example.com/oidc/callback/

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=8000
WEB_CONCURRENCY=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
